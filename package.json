{
  "name": "eremitejs",
  "private": true,
  "packageManager": "pnpm@10.33.2",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "pnpm -r run build",
    "test": "pnpm run build:packages && pnpm -r run test",
    "typecheck": "pnpm run build:packages && pnpm -r run typecheck",
    "build:packages": "pnpm -r --filter './packages/*' run build",
    "docs:dev": "pnpm --filter docs run dev",
    "docs:check": "pnpm --filter docs run broken-links"
  }
}
